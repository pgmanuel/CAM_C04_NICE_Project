# ─────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in the values for your chosen
# provider. Only ONE provider section needs to be filled in.
# The system will use whichever provider it finds first.
# ─────────────────────────────────────────────────────────────────


# ── OPTION 1: Ollama (local model — best for development) ─────────
# Install Ollama from https://ollama.com, then run:
#   ollama pull llama3.2:1b    (fast, 1GB, good for testing)
#   ollama pull llama3.2       (better quality, 2GB)
#   ollama pull mistral        (good balance, 4GB)
# Then start Ollama and set these two values:
#
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2:1b
#
# Once Ollama is working, comment out the section above and
# uncomment one of the cloud sections below.


# ── OPTION 2: OpenAI direct ───────────────────────────────────────
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini


# ── OPTION 3: OpenRouter (access to many models, one key) ─────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini


# ── Shared settings (apply to all providers) ──────────────────────
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=120

# Set to false if your local model gives errors about response_format
USE_JSON_RESPONSE_FORMAT=true
